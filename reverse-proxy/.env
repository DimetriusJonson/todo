APP_HOST_NAME=localhost,127.0.0.1
HTTP_PROXY_PORT=8080
HTTPS_PROXY_PORT=8443
APP_ADDR=127.0.0.1:3000
CERT_PATH=${CARGO_MANIFEST_DIR}/../keys/localhost_cert.crt
KEY_PATH=${CARGO_MANIFEST_DIR}/../keys/localhost_key.pem
RUST_LOG=reverse_proxy=debug,pingora=debug,resource_proxy_pingora=debug
RUST_BACKTRACE=full

STATIC_HOST_NAME=r.shz.com
STATIC_ROOT=${CARGO_MANIFEST_DIR}